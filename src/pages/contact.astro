---
// src/pages/contact.astro
// ─────────────────────────
// Update the href values below with your real links.
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — Faahim">
  <main class="contact-page page-enter">
    <h2>Get In Touch</h2>
    <p class="contact-subtitle">
      If something I wrote made you think, confused you, or annoyed you,
      you can reach me through the links below.
      Introvert-friendly communications are welcome.
    </p>
    <div class="social-links">

      <!-- GitHub — replace href with your profile URL -->
      <a href="https://github.com/Faahimfm" class="social-btn" aria-label="GitHub profile" target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.1 3.3 9.42 7.88 10.95.58.1.79-.25.79-.56v-2c-3.2.7-3.88-1.54-3.88-1.54-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.7 1.25 3.36.96.1-.75.4-1.25.73-1.54-2.56-.29-5.25-1.28-5.25-5.7 0-1.26.45-2.29 1.19-3.09-.12-.3-.52-1.47.11-3.06 0 0 .97-.31 3.18 1.19a11.1 11.1 0 012.9-.39c.98 0 1.97.13 2.9.39 2.2-1.5 3.17-1.19 3.17-1.19.63 1.59.23 2.76.11 3.06.74.8 1.19 1.83 1.19 3.09 0 4.43-2.7 5.41-5.27 5.69.42.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.56A11.51 11.51 0 0023.5 12C23.5 5.65 18.35.5 12 .5z"/>
        </svg>
      </a>

      <!-- LinkedIn — replace href with your profile URL -->
      <a href="www.linkedin.com/in/fm-faahim" class="social-btn" aria-label="LinkedIn profile" target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M19 0H5C2.239 0 0 2.239 0 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5V5c0-2.761-2.238-5-5-5zM8 19H5V8h3v11zM6.5 6.732c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zM20 19h-3v-5.604c0-3.368-4-3.113-4 0V19h-3V8h3v1.765c1.396-2.586 7-2.777 7 2.476V19z"/>
        </svg>
      </a>

      <!-- Email — replace with your address -->
      <a href="mailto:faahimrabii910@gmail.com" class="social-btn" aria-label="Send email">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M20 4H4C2.9 4 2 4.9 2 6v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
        </svg>
      </a>

    </div>
  </main>
</BaseLayout>

<script>
  // Staggered social button entry
  document.querySelectorAll('.social-btn').forEach((btn, i) => {
    setTimeout(() => btn.classList.add('visible'), 200 + i * 120);
  });
</script>
