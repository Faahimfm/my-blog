---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Hey, I'm Faahim 👋</h1>
			<p>
				CS student passionate about <strong>Machine Learning</strong>, 
				<strong>Data Science</strong>, and building things that matter.
				Currently exploring  LLM-powered tools, and computer vision projects.
			</p>
			<p>
				I write about what I learn, what I build, and occasionally about other things I find interesting.
			</p>
			<h2>Recent Projects</h2>
			<ul>
				<li><strong>EcoTrash</strong> — Smart waste management IoT system (ICRES Circularity Challenge)</li>
				<li><strong>Sri Lanka Economic Pulse</strong> — LLM-powered economic data tool</li>
			</ul>
			<h2>Start Reading</h2>
			<p>
				<a href={`${base}/blog`}>Browse all posts →</a>
			</p>
		</main>
		<Footer />
	</body>
</html>