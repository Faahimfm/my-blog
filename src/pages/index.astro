---
// src/pages/index.astro — Home page (hero only)
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Faahim — Home">
  <main class="hero page-enter">
    <h1>Hello, I'm <span class="text-gradient">Faahim</span>.</h1>
    <p class="hero-subtitle">
      I am a software engineer and writer based in Sri Lanka.
      I specialize in building minimal, accessible, and high-performance web applications.
      Welcome to my digital garden where I share my thoughts on coding, design, and the future of tech.
    </p>
    <div class="hero-btns">
      <a
        class="btn-hero primary"
        href="#"
        target="_blank"
        rel="noopener noreferrer"
      >
        <!-- Replace href="#" with your portfolio URL -->
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M3 3h7v2H5v14h14v-5h2v7H3V3zm11 0h7v7h-2V6.414l-9.293 9.293-1.414-1.414L17.586 5H14V3z"/>
        </svg>
        View Portfolio
      </a>
      <a class="btn-hero ghost" href="/articles">
        Read Articles
      </a>
    </div>
  </main>
</BaseLayout>