---
import BaseLayout from '../../layouts/BaseLayout.astro';

const allArticles = await Astro.glob('../../content/articles/*.md');

const articles = allArticles
  .map(a => ({
    title:       a.frontmatter.title,
    description: a.frontmatter.description,
    date:        a.frontmatter.date,
    tags:        a.frontmatter.tags || [],
    slug:        a.frontmatter.slug || a.file.split('/').pop().replace('.md',''),
    url:         `/my-blog/articles/${a.frontmatter.slug || a.file.split('/').pop().replace('.md','')}`,
  }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

// Collect all unique tags
const allTags = [...new Set(articles.flatMap(a => a.tags))].sort();

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric', month: 'short', day: 'numeric',
  });
}
---

<BaseLayout title="Articles — Faahim">
  <main class="inner-page inner-page--wide page-enter">
    <h2>Recent Writings</h2>

    <!-- TAG FILTER -->
    {allTags.length > 0 && (
      <div class="tag-filter">
        <button class="tag-btn active" data-tag="all">All</button>
        {allTags.map(tag => (
          <button class="tag-btn" data-tag={tag}>{tag}</button>
        ))}
      </div>
    )}

    <!-- ARTICLES GRID -->
    <div class="blog-grid" id="articles-grid">
      {articles.map(article => (
        <article
          class="card"
          data-tags={article.tags.join(',')}
        >
          <a href={article.url} aria-label={`Read: ${article.title}`}>
            <span class="card-date">{formatDate(article.date)}</span>
            <h3>{article.title}</h3>
            <p>{article.description}</p>
            {article.tags.length > 0 && (
              <div class="card-tags">
                {article.tags.map(tag => (
                  <span class="card-tag">{tag}</span>
                ))}
              </div>
            )}
          </a>
        </article>
      ))}
    </div>

    <!-- EMPTY STATE -->
    <div class="no-results" id="no-results" style="display:none;">
      <p>No articles found for this tag.</p>
    </div>

  </main>
</BaseLayout>

<style is:global>
  /* ── TAG FILTER BAR ── */
  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2.5rem;
  }

  .tag-btn {
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-size: 0.82rem;
    font-weight: 600;
    font-family: inherit;
    letter-spacing: 0.04em;
    cursor: pointer;
    border: 1px solid var(--border-color);
    background: transparent;
    color: var(--text-muted);
    transition: background 0.2s ease, color 0.2s ease,
                border-color 0.2s ease, transform 0.15s ease;
  }

  .tag-btn:hover {
    border-color: var(--text-muted);
    color: var(--text-main);
    transform: translateY(-1px);
  }

  .tag-btn.active {
    background: var(--text-main);
    color: var(--bg-color);
    border-color: var(--text-main);
  }

  /* ── CARD TAGS ── */
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 1rem;
  }

  .card-tag {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 0.2rem 0.55rem;
  }

  /* ── CARD HIDE/SHOW ── */
  .card {
    transition: opacity 0.35s ease, transform 0.35s ease,
                background 0.3s ease, border-color 0.3s ease,
                box-shadow 0.3s ease;
  }

  .card.hidden {
    display: none;
  }

  /* ── EMPTY STATE ── */
  .no-results {
    text-align: center;
    color: var(--text-muted);
    padding: 4rem 0;
    font-size: 1rem;
    width: 100%;
  }
</style>

<script>
  // Staggered entry animation
  document.querySelectorAll('.card').forEach((card, i) => {
    setTimeout(() => card.classList.add('visible'), 80 + i * 90);
  });

  // Tag filter
  const tagBtns = document.querySelectorAll('.tag-btn');
  const cards   = document.querySelectorAll('.card');
  const noResults = document.getElementById('no-results');

  tagBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.getAttribute('data-tag');

      // Update active button
      tagBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      // Filter cards
      let visible = 0;
      cards.forEach((card, i) => {
        const cardTags = card.getAttribute('data-tags') || '';
        const matches  = tag === 'all' || cardTags.split(',').includes(tag);

        if (matches) {
          card.classList.remove('hidden');
          // Re-animate visible cards
          card.classList.remove('visible');
          setTimeout(() => card.classList.add('visible'), 50 + visible * 70);
          visible++;
        } else {
          card.classList.add('hidden');
          card.classList.remove('visible');
        }
      });

      // Show/hide empty state
      if (noResults) {
        noResults.style.display = visible === 0 ? 'block' : 'none';
      }
    });
  });
</script>
