---
// src/pages/journey.astro
import BaseLayout from '../layouts/BaseLayout.astro';

// ─────────────────────────────────────────────────────
// EDIT YOUR TIMELINE HERE
// Each entry: { year, title, description, now?: true }
// ─────────────────────────────────────────────────────
const timeline = [
  {
    year: "Before 2022",
    title: "Ground Zero",
    description: "idn’t even know how to copy and paste on a computer — starting completely from scratch.",
  },
  {
    year: "2023",
    title: "First Breakthrough",
    description: "Learned my first programming language - Java, and completed a Diploma in Cyber Security & Ethical Hacking.",
  },
  {
    year: "2024",
    title: "Understanding the Wires",
    description: "Studied computer networking to understand how systems connect and communicate.",
  },
  {
    year: "2025",
    title: "Leveling Up",
    description: "Selected for the Computer Science Honours Degree program and began diving deeper into advanced computing. Started caring deeply about performance, accessibility, and maintainability — not just what works, but what lasts and what scales.",
  },
  {
    year: "2026",
    title: "into Intelligent Systems",
    description: " Developed a strong interest in Data Science and Machine Learning, currently building my own NLP model.",
  },
  
];
---

<BaseLayout title="Journey — Faahim">
  <main class="inner-page page-enter">
    <h2>The Journey</h2>
    <div class="timeline">
      {timeline.map(item => (
        <div class={`timeline-item${item.now ? ' now' : ''}`}>
          <div class="timeline-year">{item.year}</div>
          <div class="timeline-title">{item.title}</div>
          <p class="timeline-desc">{item.description}</p>
        </div>
      ))}
    </div>
  </main>
</BaseLayout>

<script>
  // Staggered timeline entry animation
  document.querySelectorAll('.timeline-item').forEach((el, i) => {
    setTimeout(() => el.classList.add('visible'), 100 + i * 105);
  });
</script>
