---
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const allArticles = await Astro.glob('../../content/articles/*.md');
  return allArticles.map(a => {
    const slug = a.frontmatter.slug || a.file.split('/').pop().replace('.md','');
    return { params: { slug }, props: { article: a } };
  });
}

const { article } = Astro.props;
const { title, description, date } = article.frontmatter;
const Content = article.Content;

function formatDate(dateStr) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric', month: 'long', day: 'numeric',
  });
}
---

<BaseLayout title={`${title} — Faahim`} description={description}>
  <main class="article-page page-enter">
    <a href="/my-blog/articles" class="article-back">← Back to Articles</a>
    <p class="article-meta">{formatDate(date)}</p>
    <h1>{title}</h1>
    <div class="article-body">
      <Content />
    </div>
  </main>
</BaseLayout>

<style is:global>
  .article-body img {
    width: 100% !important;
    max-width: 100% !important;
    height: auto !important;
    display: block !important;
    border-radius: 10px;
    border: 1px solid var(--border-color);
    box-sizing: border-box !important;
    margin: 2rem 0 0.5rem;
  }

  .article-body p:has(> img) {
    margin: 2rem 0 0.5rem !important;
    line-height: 0 !important;
    font-size: 0 !important;
    width: 100% !important;
    box-sizing: border-box !important;
    display: block !important;
  }

  .article-body p:has(> img) + p > em:only-child {
    display: block;
    font-size: 0.82rem !important;
    line-height: 1.5 !important;
    color: var(--text-muted);
    opacity: 0.75;
    text-align: center;
    margin-bottom: 2rem;
  }
</style>
