---
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const allArticles = await Astro.glob('../../content/articles/*.md');
  return allArticles.map(a => {
    const slug = a.frontmatter.slug || a.file.split('/').pop().replace('.md','');
    return { params: { slug }, props: { article: a } };
  });
}

const { article } = Astro.props;
const { title, description, date } = article.frontmatter;
const rawHtml = article.compiledContent();

function formatDate(dateStr) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric', month: 'long', day: 'numeric',
  });
}
---

<BaseLayout title={`${title} — Faahim`} description={description}>
  <main class="article-page page-enter">
    <a href="/my-blog/articles" class="article-back">← Back to Articles</a>
    <p class="article-meta">{formatDate(date)}</p>
    <h1>{title}</h1>
    <div class="article-body" set:html={rawHtml} />
  </main>
</BaseLayout>